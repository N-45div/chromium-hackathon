# Ethereum Node RPC URL (e.g., from Infura, Alchemy, or a local node)
SOURCE_CHAIN_RPC_URL="https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID"

# Private key for the account that will trigger liquidations
LIQUIDATOR_PRIVATE_KEY="0x_your_private_key_here"

# Address of the deployed CollManagement contract on the source chain
COLL_MANAGEMENT_CONTRACT_ADDRESS="0x_your_contract_address_here"
