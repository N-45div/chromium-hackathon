# Configuration for the Liquidation Agent

# The HTTP RPC endpoint for the blockchain network.
RPC_URL="https://your-rpc-provider.com/api-key"

# The deployed address of the CollManagement contract.
CONTRACT_ADDRESS="0x..."

# The private key of the wallet that will execute the liquidation transactions.
# IMPORTANT: Do not commit a file with a real private key to version control.
PRIVATE_KEY="0x..."

# A comma-separated list of borrower addresses to monitor.
BORROWERS="0xAddress1,0xAddress2,0xAddress3"
